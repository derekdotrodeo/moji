# ── App ──
NODE_ENV=development
PORT=3000
# Public origin the client is served from (used for CORS / socket origin checks)
PUBLIC_ORIGIN=http://localhost:3000

# Secret used to sign reconnection session tokens. Generate a long random value.
SESSION_SECRET=change-me-to-a-long-random-string

# Log incorrect guesses + the answer to stdout (handy for tuning the matcher
# during playtests). Set to false to silence.
LOG_GUESS_MISSES=true

# ── Database (Postgres) ──
# Matches the docker-compose 'db' service defaults for local dev.
DATABASE_URL=postgres://moji:moji@localhost:5432/moji

# ── Client (Vite) ──
# In single-container prod the client talks to its own origin, so leave blank.
# For split dev (vite dev server on :5173 -> api on :3000) point it at the server.
VITE_SERVER_URL=http://localhost:3000

# ── Cloudflare Tunnel ──
# Token from `cloudflared tunnel` (Zero Trust dashboard). Used by the cloudflared
# service in docker-compose. Leave blank locally if not tunneling.
CLOUDFLARE_TUNNEL_TOKEN=
